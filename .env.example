DATABASE_URL="postgresql://user:password@host:5432/dbname"

# LINE Messaging API (Developers Console > your channel > Messaging API tab)
LINE_CHANNEL_SECRET=""
LINE_CHANNEL_ACCESS_TOKEN=""

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=""

# Vercel Blob storage — used to back up LINE slip images. Auto-injected by
# Vercel when you create a Blob store (Storage tab); for local dev, copy the
# token from Vercel project settings. Slip image backup is skipped silently
# if this is unset.
BLOB_READ_WRITE_TOKEN=""

# LINE group or user ID that receives forwarded service requests (e.g. a
# loan application) when a member sends a supporting document like a
# payslip or ID copy instead of a transfer slip. The bot must already be a
# member of the target group (or friends with the target user) to push
# messages to it. Forwarding is skipped (with a warning logged) if unset.
LINE_FORWARD_TARGET_ID=""
