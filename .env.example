DATABASE_URL="postgresql://user:password@host:5432/dbname"

# LINE Messaging API (Developers Console > your channel > Messaging API tab)
LINE_CHANNEL_SECRET=""
LINE_CHANNEL_ACCESS_TOKEN=""

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=""

# Vercel Blob storage — used to back up LINE slip images. Auto-injected by
# Vercel when you create a Blob store (Storage tab); for local dev, copy the
# token from Vercel project settings. Slip image backup is skipped silently
# if this is unset.
BLOB_READ_WRITE_TOKEN=""

# LINE user IDs that receive forwarded service requests when a member
# sends a supporting document (payslip, ID copy, etc.) instead of a
# transfer slip and states what it's for. LINE_FORWARD_LOAN_ID is used for
# anything loan-related (falls back to it when the member's district has
# no confirmed contact in LoanDistrictContact); LINE_FORWARD_GENERAL_ID is
# used for everything else. Must be a user ID the bot is friends with
# (unverified Official Accounts generally can't be added to LINE groups —
# use a specific staff member's personal LINE, not a group). Forwarding is
# skipped (with a warning logged, and the user told honestly) if unset.
LINE_FORWARD_LOAN_ID=""
LINE_FORWARD_GENERAL_ID=""
