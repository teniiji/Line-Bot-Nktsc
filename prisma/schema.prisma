generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Expense {
  id              String   @id @default(cuid())
  amount          Float
  category        String
  description     String?
  date            DateTime
  createdAt       DateTime @default(now())
  lineUserId      String?
  // Bank/wallet-issued transaction reference number read off a slip, if
  // visible. Globally unique in the real world, so it doubles as a
  // duplicate-slip guard — resubmitting the same slip hits this constraint
  // instead of creating a second row. Not fully reliable on its own since
  // it depends on the vision model reading the exact same text on every
  // submission — slipImageHash below is the more robust guard.
  referenceNumber String?  @unique
  // SHA-256 of the raw slip image bytes. Unlike referenceNumber, this is
  // deterministic — resending the literal same photo always hashes
  // identically regardless of what the model manages to read off it — so
  // it's the primary duplicate-slip guard; referenceNumber is a secondary
  // one for cases where the same transaction is photographed twice.
  slipImageHash   String?  @unique
  slipImageUrl    String?
  // Snapshot of the member's identity and (for ชำระหนี้) the loan type at
  // the moment this transaction was logged — copied from LineUser rather
  // than joined live, so the record stays accurate even if the member's
  // saved name changes later.
  memberFullName  String?
  memberNumber    String?
  // Whether the member's number matched the imported roster at log time —
  // false means it was self-asserted and unverified, so staff should check.
  memberVerified  Boolean  @default(false)
  loanType        String?
  // Best-effort staff notification, mirroring ServiceRequestLog's
  // forwardedTo/status: which department's officer(s) (resolved from the
  // transaction's category via CATEGORY_DEPARTMENTS) got pushed a message
  // about this transaction, and whether it succeeded. Never blocks logging
  // the transaction itself — null forwardStatus means the push was never
  // attempted (e.g. an older row from before this feature existed).
  forwardedTo     String?
  forwardStatus   String?

  @@index([date])
  @@index([category])
  // get_transaction_summary always filters by lineUserId, often together
  // with a date range — a composite index serves that directly instead of
  // Postgres bitmap-AND-ing two single-column indexes. Still usable for
  // lineUserId-only lookups since it's the leading column, so the old
  // standalone index([lineUserId]) is redundant with this.
  @@index([lineUserId, date])
}

// Records LINE webhook events that have already been processed, so a
// retried delivery (LINE re-sends on timeout / non-2xx) is a no-op instead
// of re-running the finance agent and creating a duplicate expense.
model ProcessedLineEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

// An in-progress cooperative transaction the agent is still collecting
// required info for (member identity, transfer slip, and — for ชำระหนี้ —
// loan type) across multiple separate, stateless webhook calls. Holds
// whatever has been supplied so far per LINE user until every requirement
// is met (at which point it's converted into an Expense and deleted), or it
// expires unanswered.
model PendingTransaction {
  id              String    @id @default(cuid())
  lineUserId      String    @unique
  category        String?
  amount          Float?
  description     String?
  date            DateTime?
  // Whether a slip image has been seen for this transaction — tracked
  // separately from slipImageUrl because the Blob upload it depends on is
  // best-effort (skipped entirely if BLOB_READ_WRITE_TOKEN isn't set) and
  // must never gate whether the flow can proceed.
  hasSlip         Boolean   @default(false)
  slipImageHash   String?
  slipImageUrl    String?
  referenceNumber String?
  loanType        String?
  createdAt       DateTime  @default(now())
}

// A supporting document (payslip, ID card copy, house registration copy,
// marriage certificate) the user sent that isn't a transfer slip — these
// are typically submitted for some other cooperative service (e.g. a loan
// application) this bot doesn't itself process. Holds the document type
// while the agent asks what it's for, then — once member identity is also
// known — forwards the request to LINE_FORWARD_TARGET_ID and clears.
model PendingServiceRequest {
  id           String   @id @default(cuid())
  lineUserId   String   @unique
  documentType String
  requestType  String?
  // "สินเชื่อ" | "อื่นๆ" — which forwarding pool this request routes
  // through. Set together with requestType by submit_service_purpose.
  department   String?
  // Best-effort Vercel Blob URL of the document image the member sent
  // (null if BLOB_READ_WRITE_TOKEN isn't set or the upload failed) —
  // forwarded to staff as an image message alongside the text summary.
  imageUrl     String?
  createdAt    DateTime @default(now())
}

// One row per LINE user who has ever messaged the bot, keyed by their LINE
// userId. displayName is fetched from LINE's profile API the first time we
// see a user (best-effort, may be null if that call fails); nickname is set
// by the user themselves via the finance agent's set_nickname tool.
// fullName/memberNumber are collected once via the finance agent's
// submit_member_info tool the first time the user reports a cooperative
// transaction, then reused for every later transaction without asking
// again. Lets the web dashboard show a name instead of a raw LINE userId.
// phone is collected once via submit_contact_phone, only when a supporting-
// document service request is being forwarded to staff (not needed for
// ordinary transaction logging) — reused on later requests the same way.
// Deliberately not a Prisma relation to Expense.lineUserId — that field
// predates this table and can reference ids with no row here yet (or ever,
// for pre-existing data).
model LineUser {
  id           String   @id
  displayName  String?
  nickname     String?
  fullName     String?
  memberNumber String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Reference directory of cooperative-affiliated organizations (schools,
// government units, pension groups by district) — imported from an
// existing spreadsheet maintained outside this app (scripts/import-org-data.ts).
// lineUserId here is whoever currently receives that unit's monthly
// deduction-report ("รายการหัก") notification — NOT automatically the
// right person for a new loan service request; see LoanDistrictContact
// for that, which is deliberately kept separate.
model OrganizationUnit {
  id            String   @id @default(cuid())
  name          String   @unique
  groupName     String?
  contactMethod String?
  contactName   String?
  email         String?
  lineUserId    String?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Roster of cooperative members already known from the LINE OA — imported
// from an existing spreadsheet (scripts/import-org-data.ts), including
// which organizational unit/district they're affiliated with. Used to look
// up a member's district when routing a loan service request. A separate,
// richer source than LineUser, which this bot only populates from what
// members type in via submit_member_info.
model MemberRoster {
  id           String   @id @default(cuid())
  memberNumber String   @unique
  memberName   String
  unitName     String?
  // Short per-member "รหัสผู้รับผิดชอบ" code (e.g. a single digit),
  // imported from column H of the "สมาชิก_LINE_OA" sheet — looked up in
  // ResponsibleContact to find the loan officer for this member directly.
  // Primary loan-routing mechanism (see resolveForwardTarget in
  // lib/financeAgent.ts): a short code is far less prone to spreadsheet
  // typos than the free-text unitName match against LoanDistrictContact,
  // which remains as a secondary fallback for members without a code.
  responsibleCode String?
  lineUserId   String?
  nickname     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([lineUserId])
}

// One editable line of the agent's "ข้อมูลอ้างอิงของสหกรณ์" system-prompt
// block (interest rates, welfare, contact info). Staff maintain these from
// the dashboard so a rate change no longer requires a code edit + deploy.
// Seeded by the migration with the values previously hard-coded in
// lib/financeAgent.ts; lib/knowledge.ts falls back to the same defaults if
// the table is ever empty.
model KnowledgeEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  content   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Audit log of every supporting-document service request the bot attempted
// to forward to staff — written just before PendingServiceRequest is
// cleared, which previously left no record of who asked for what, who it
// went to, or whether the push succeeded. One row per attempt; status is
// "forwarded" (push succeeded), "failed" (push errored), or
// "unconfigured" (no forward target was set up). Member identity is
// snapshotted here the same way Expense snapshots it, so the log stays
// accurate if the member later changes their saved name.
model ServiceRequestLog {
  id             String   @id @default(cuid())
  lineUserId     String
  memberFullName String?
  memberNumber   String?
  memberVerified Boolean  @default(false)
  phone          String?
  documentType   String
  requestType    String?
  department     String?
  imageUrl       String?
  // LINE user ID of the staff member the request was pushed to (null when
  // status is "unconfigured").
  forwardedTo    String?
  status         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([lineUserId])
}

// Who to forward a loan (สินเชื่อ/กู้เงิน) service request to for a given
// organizational unit, matched exactly against MemberRoster.unitName (e.g.
// "บำนาญ อ.เมือง นค.") — the cooperative's staff assignments are per-unit,
// not per-district, and one staff member typically covers many units, so
// this is a many-to-one mapping keyed by the unit itself rather than a
// coarser district code. Deliberately separate from OrganizationUnit.lineUserId
// and starts empty — populated via scripts/import-loan-contacts.ts. A unit
// with no row here (including every unit until first populated) falls back
// to LINE_FORWARD_LOAN_ID.
model LoanDistrictContact {
  id         String   @id @default(cuid())
  unitName   String   @unique
  lineUserId String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Primary loan-routing mapping: a short "รหัสผู้รับผิดชอบ" code (e.g. a
// single digit) assigned per-member in the cooperative's "ผู้รับผิดชอบ"
// sheet, imported via scripts/import-responsible-contacts.ts. Each member's
// MemberRoster.responsibleCode is looked up here first in
// resolveForwardTarget — a code is far less prone to spreadsheet-typo
// mismatches than free-text unit-name matching, and this table typically
// has only a handful of rows (one per loan officer) versus one row per
// organizational unit for LoanDistrictContact. Falls through to
// LoanDistrictContact / unitName matching, then LINE_FORWARD_LOAN_ID, for
// members with no responsibleCode or an unmatched one.
model ResponsibleContact {
  id         String   @id @default(cuid())
  code       String   @unique
  lineUserId String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Staff who receive service requests for a given non-loan department (e.g.
// เงินฝาก, บัญชี, สวัสดิการ) — many-to-one: several officers can share a
// department, and every request is broadcast to all of them (see
// resolveForwardTargets in lib/financeAgent.ts) so nobody is missed
// regardless of who's on duty. Managed directly from the dashboard, not an
// import script, since these assignments change more often than loan
// routing. A department with no rows here falls back to
// LINE_FORWARD_GENERAL_ID.
model DepartmentContact {
  id         String   @id @default(cuid())
  department String
  lineUserId String
  name       String?
  createdAt  DateTime @default(now())

  @@unique([department, lineUserId])
  @@index([department])
}
